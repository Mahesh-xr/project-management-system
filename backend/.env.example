# Server configuration
PORT=5000

# PostgreSQL connection string for Prisma
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/project_management_db?schema=public"

# Secret key used for signing JSON Web Tokens (JWT)
JWT_SECRET="your_jwt_secret_key_here_change_in_production"
